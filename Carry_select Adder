module top_module( input [31:0] a, input [31:0] b, output [31:0] sum);
    wire c2;
    wire [15:0]s1,s2;
    reg  c1=0, c3=1;
    add16 inst1(.a(a[15:0]), .b(b[15:0]),.cin(c1),.sum(sum[15:0]), .cout(c2));
    add16 inst2(.a(a[31:16]), .b(b[31:16]),.cin(c1),.sum(s1));
    add16 inst3(.a(a[31:16]), .b(b[31:16]),.cin(c3),.sum(s2)); 
    always@(*)begin
        case(c2)
            0: sum[31:16] = s1;
            1: sum[31:16] = s2;
        endcase
    end
endmodule
